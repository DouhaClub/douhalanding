# Copie para .env e preencha (Supabase → Project Settings → API)

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# YouTube Data API v3 — Google Cloud: Biblioteca → ativar "YouTube Data API v3".
# Credenciais → chave de API: em desenvolvimento, restricao "Sites" com http://localhost:5180/* (ou sem restricao so pra testar).
# VITE_YOUTUBE_CHANNEL_ID = ID UC... OU handle sem @ (ex.: douhaclub)
# Shorts: removemos uploads com duracao <= N segundos (padrao 60). Se no futuro Shorts forem mais longos, suba o valor.
VITE_YOUTUBE_SHORTS_MAX_SECONDS=60
VITE_YOUTUBE_API_KEY=
VITE_YOUTUBE_CHANNEL_ID=
